# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Next.js Environment
NODE_ENV=development

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://www.calldrboyle.com

# Google Search Console — HTML tag method (content value only, not the full meta tag)
GOOGLE_SITE_VERIFICATION=

# Optional: GA4 measurement ID (links Analytics to Search Console)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional: Bing Webmaster Tools verification
BING_SITE_VERIFICATION=
