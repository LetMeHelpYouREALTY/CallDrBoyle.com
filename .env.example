# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Anthropic (optional — Claude chat / lead qualification)
ANTHROPIC_API_KEY=

NODE_ENV=development

# --- Site & Search Console (required for production SEO) ---
NEXT_PUBLIC_SITE_URL=https://www.calldrboyle.com
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# --- Analytics ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Google Maps (use NEXT_PUBLIC_* ; VITE_* is legacy fallback only) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- RealScout widgets (encoded agent id from RealScout dashboard) ---
NEXT_PUBLIC_REALSCOUT_AGENT_ENCODED_ID=
# If your Vercel name is FOLLOW_UP_BOSS_AGENT_ID, set it to the RealScout encoded id
# OR use a numeric FUB user id for lead assignment (see FUB_API_KEY below)
FOLLOW_UP_BOSS_AGENT_ID=

# --- Follow Up Boss (lead capture API) ---
FUB_API_KEY=
FUB_SYSTEM_KEY=

# --- Cloudinary ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=

# --- Cloudflare (DNS / origin / Workers) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ORIGIN_CA_KEY=

# --- Notion (Production + Preview recommended) ---
NOTION_TOKEN=

# --- SMS automation ---
SMS_AUTO_REPLY_ENABLED=false

# --- Cloudflare Turnstile (forms) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Sentry (optional) ---
NEXT_PUBLIC_SENTRY_DSN=

# Legacy — do not add new Vite-prefixed vars for Next.js
# VITE_GOOGLE_MAPS_API_KEY=
